                "api",
                "v1",
                "scraper",
                "images"
              ],
              "query": [
                {
                  "key": "url",
                  "value": "{{samplePageUrl}}"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('scraper returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const expectedA = pm.environment.get('sampleImageAUrl');",
                  "const expectedB = pm.environment.get('sampleImageBUrl');",
                  "",
                  "pm.test('response has imageSources array', function () {",
                  "  pm.expect(body).to.have.property('imageSources');",
                  "  pm.expect(body.imageSources).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('relative URLs are resolved and duplicate order is preserved', function () {",
                  "  pm.expect(body.imageSources).to.eql([",
                  "    expectedA,",
                  "    expectedB,",
                  "    expectedA",
                  "  ]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
