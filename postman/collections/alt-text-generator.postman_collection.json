    {
      "name": "30 Page Descriptions (Azure Stub)",
      "item": [
        {
          "name": "Describe all images on fixture page",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accessibility/descriptions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accessibility",
                "descriptions"
              ],
              "query": [
                {
                  "key": "url",
                  "value": "{{samplePageUrl}}"
                },
                {
                  "key": "model",
                  "value": "{{model}}"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('page descriptions return 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const expectedA = pm.environment.get('sampleImageAUrl');",
                  "const expectedB = pm.environment.get('sampleImageBUrl');",
                  "const expectedPageUrl = pm.environment.get('samplePageUrl');",
                  "",
                  "const schema = {",
                  "  type: 'object',",
                  "  required: ['pageUrl', 'model', 'totalImages', 'uniqueImages', 'descriptions'],",
                  "  properties: {",
                  "    pageUrl: { type: 'string' },",
                  "    model: { type: 'string' },",
                  "    totalImages: { type: 'integer' },",
                  "    uniqueImages: { type: 'integer' },",
                  "    descriptions: {",
                  "      type: 'array',",
                  "      items: {",
                  "        type: 'object',",
                  "        required: ['description', 'imageUrl'],",
                  "        properties: {",
                  "          description: { type: 'string' },",
                  "          imageUrl: { type: 'string' }",
                  "        }",
                  "      }",
                  "    }",
                  "  }",
                  "};",
                  "",
                  "pm.test('response schema is valid', function () {",
                  "  pm.response.to.have.jsonSchema(schema);",
                  "});",
                  "",
                  "pm.test('page metadata is correct', function () {",
                  "  pm.expect(body.pageUrl).to.eql(expectedPageUrl);",
                  "  pm.expect(body.model).to.eql('azure');",
                  "  pm.expect(body.totalImages).to.eql(3);",
                  "  pm.expect(body.uniqueImages).to.eql(2);",
                  "});",
                  "",
                  "pm.test('duplicate output order is preserved', function () {",
                  "  pm.expect(body.descriptions.map((item) => item.imageUrl)).to.eql([",
                  "    expectedA,",
                  "    expectedB,",
                  "    expectedA",
                  "  ]);",
                  "});",
                  "",
                  "pm.test('descriptions match expected stub captions', function () {",
                  "  pm.expect(body.descriptions).to.eql([",
                  "    { description: 'stub caption for asset a', imageUrl: expectedA },",
                  "    { description: 'stub caption for asset b', imageUrl: expectedB },",
                  "    { description: 'stub caption for asset a', imageUrl: expectedA }",
                  "  ]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
