NODE_ENV=development
PORT=8080
TLS_PORT=8443

# Configure at least one provider before booting the app.
# Replicate enables the `clip` model.
# REPLICATE_API_TOKEN=replace-me
# Azure enables the `azure` model.
# ACV_API_ENDPOINT=https://example.cognitiveservices.azure.com/computervision/imageanalysis:analyze?api-version=2024-02-01
# ACV_SUBSCRIPTION_KEY=replace-me
# Ollama enables the `ollama` model when either OLLAMA_MODEL or OLLAMA_BASE_URL is set.
# OLLAMA_MODEL=llama3.2-vision
# OpenAI-compatible providers register when their API key is set.
# OPENAI_API_KEY=replace-me
# HF_API_KEY=replace-me
# OPENROUTER_API_KEY=replace-me
# TOGETHER_API_KEY=replace-me

# Optional Replicate overrides.
# REPLICATE_API_ENDPOINT=https://api.replicate.com/v1/
# REPLICATE_USER_AGENT=alt-text-generator/1.0.0
# REPLICATE_MODEL_OWNER=rmokady
# REPLICATE_MODEL_NAME=clip_prefix_caption
# REPLICATE_MODEL_VERSION=9a34a6339872a03f45236f114321fb51fc7aa8269d38ae0ce5334969981e4cd8

# Optional worker and scraper controls.
# WORKER_COUNT=1 runs a single process with no internal cluster manager.
# TRUST_PROXY_HOPS=1
# WORKER_COUNT=1
# CLUSTER_RESTART_BACKOFF_MS=1000
# CLUSTER_RESTART_MAX_BACKOFF_MS=30000
# CLUSTER_CRASH_WINDOW_MS=60000
# CLUSTER_MAX_CRASHES=5
# CLUSTER_SHUTDOWN_TIMEOUT_MS=10000
# SCRAPER_REQUEST_TIMEOUT_MS=10000
# SCRAPER_MAX_REDIRECTS=5
# SCRAPER_MAX_CONTENT_LENGTH_BYTES=2097152
# PAGE_DESCRIPTION_CONCURRENCY=3

# Optional app-managed supplemental CA bundle for outbound HTTPS.
# OUTBOUND_CA_BUNDLE_FILE=/absolute/path/to/outbound-extra-ca.pem

# Optional rate limiting and logging.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# LOG_LEVEL=debug

# Optional API access control. When set, scraper and description endpoints
# require either `Authorization: Bearer <token>` or `X-API-Key: <token>`.
# Health, ping, and Swagger docs remain public.
# API_AUTH_ENABLED=true
# API_AUTH_TOKENS=replace-me,rotate-me

# Optional Swagger URLs.
# SWAGGER_DEV_URL=https://localhost:8443
# SWAGGER_PROD_URL=https://wcag.qcraft.com.br

# Optional Azure provider settings. Set ACV_API_ENDPOINT and
# ACV_SUBSCRIPTION_KEY to register the `azure` model at startup.
# ACV_API_ENDPOINT=
# ACV_SUBSCRIPTION_KEY=
# ACV_LANGUAGE=en
# ACV_MAX_CANDIDATES=4

# Optional Ollama provider settings. Set OLLAMA_MODEL or OLLAMA_BASE_URL
# to register the `ollama` model.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2-vision
# OLLAMA_PROMPT=Write concise alt text for this image.
# OLLAMA_KEEP_ALIVE=5m

# Optional OpenAI provider settings.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-nano
# OPENAI_MAX_TOKENS=160
# OPENAI_PROMPT=Write concise alt text for this image.

# Optional Hugging Face provider settings. `HF_TOKEN` is accepted as an alias
# for `HF_API_KEY`.
# HF_API_KEY=
# HF_BASE_URL=https://router.huggingface.co/v1
# HF_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct:fastest
# HF_MAX_TOKENS=160
# HF_PROMPT=Write concise alt text for this image.

# Optional OpenRouter provider settings.
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemma-3-4b-it:free
# OPENROUTER_MAX_TOKENS=160
# OPENROUTER_PROMPT=Write concise alt text for this image.
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_TITLE=Alt-Text 4 All

# Optional Together provider settings.
# TOGETHER_API_KEY=
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# TOGETHER_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct
# TOGETHER_MAX_TOKENS=160
# TOGETHER_PROMPT=Write concise alt text for this image.

# Development TLS defaults already point to the checked-in localhost certs.
# Uncomment only when overriding them.
# TLS_KEY=../../certs/localhost-key.pem
# TLS_CERT=../../certs/localhost.pem
