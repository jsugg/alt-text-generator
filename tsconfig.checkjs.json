{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "node20",
    "target": "ES2022",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.js",
    "config/**/*.js",
    "scripts/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "reports",
    "tests"
  ]
}
